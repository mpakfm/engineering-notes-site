---
import '../styles/global.css';
const { title = 'mpakfm — рабочие заметки инженера' } = Astro.props;
const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <div class="container">
      <header class="site">
        <a href="/" class="brand" aria-label="mpakfm — рабочие заметки инженера">
          <span class="brand-text">
            <span class="brand-name">mpakfm</span>
            <span class="brand-subtitle">рабочие заметки инженера</span>
          </span>
        </a>
        <nav class="desktop" aria-label="Основная навигация">
          <a href="/" class={isActive('/') ? 'active' : undefined}>Главная</a>
          <a href="/notes/" class={isActive('/notes/') ? 'active' : undefined}>Заметки</a>
          <a href="/about/" class={isActive('/about/') ? 'active' : undefined}>Обо мне</a>
        </nav>

        <details class="mobile-menu">
          <summary aria-label="Открыть меню">☰</summary>
          <nav class="mobile-nav" aria-label="Мобильная навигация">
            <a href="/notes/">Заметки</a>
            <a href="/about/">Обо мне</a>
          </nav>
        </details>
      </header>
      <slot />
      <footer class="footer">
        <div>
          <strong>mpakfm</strong>
          <span>рабочие заметки инженера</span>
        </div>
        <p>Документируй то, что узнал сегодня, чтобы завтра не разбираться заново.</p>
        <nav aria-label="Ссылки в подвале">
          <a href="/notes/">Заметки</a>
          <a href="/about/">Обо мне</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
