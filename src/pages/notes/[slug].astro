---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugFromContentId } from '../../utils/content';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({ params: { slug: slugFromContentId(note.id) }, props: { note } }));
}
const { note } = Astro.props;
const { Content } = await render(note);
---
<BaseLayout title={note.data.title}>
  <article class="card">
    <h1>{note.data.title}</h1>
    <p>{note.data.description}</p>
    <div class="meta">{note.data.tags.map((t: string)=><span class="tag">{t}</span>)} · {note.data.pubDate.toLocaleDateString('ru-RU')} · {note.data.readingTime}</div>
    <Content />
  </article>
</BaseLayout>
