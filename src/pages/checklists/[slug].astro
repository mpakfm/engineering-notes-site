---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { slugFromContentId } from '../../utils/content';

export async function getStaticPaths() {
  const entries = await getCollection('checklists', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: slugFromContentId(entry.id) }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title}>
  <article class="card">
    <h1>{entry.data.title}</h1>
    <p>{entry.data.description}</p>
    <div class="meta">{entry.data.tags.map((t: string)=><span class="tag">{t}</span>)}</div>
    <Content />
  </article>
</BaseLayout>
