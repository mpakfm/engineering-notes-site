---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { slugFromContentId } from '../utils/content';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort((a,b)=>b.data.pubDate.getTime()-a.data.pubDate.getTime());
const checklists = (await getCollection('checklists', ({ data }) => !data.draft)).sort((a,b)=>b.data.pubDate.getTime()-a.data.pubDate.getTime());
const topics = [...new Set(notes.flatMap((n) => n.data.tags))].slice(0, 10);

const hrefFor = (collection: 'notes' | 'checklists', id: string) => `/${collection}/${slugFromContentId(id)}/`;
const startItems = notes.slice(0, 4);

const iconThemes = ['green', 'blue', 'orange', 'violet'];
---
<BaseLayout>
  <main class="home-layout">
    <div class="home-main">
      <section class="hero card">
        <span class="notebook-binding" aria-hidden="true"></span>
        <div class="hero-copy">
          <p class="eyebrow">инженерный блокнот</p>
          <h1>Рабочие заметки инженера</h1>
          <p>Пишу про веб-разработку, внутренние системы, интеграции, Bitrix, Git, релизы, процессы и жизнь с AI-агентами, которые всё чаще становятся частью обычной рабочей рутины.</p>
          <div class="hero-facts" aria-label="Принципы материалов">
            <span>
              <svg class="fact-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M9 5.5h6" />
                <path d="M10 4h4l1 2h3v13H6V6h3z" />
                <path d="M9 12h6" />
                <path d="M9 16h4" />
              </svg>
              <strong>Из практики</strong>
              <small>без теории ради теории</small>
            </span>
            <span>
              <svg class="fact-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20 12a8 8 0 1 1-2.35-5.65" />
                <path d="M20 5v5h-5" />
                <path d="m9.5 12.5 1.8 1.8 3.7-4.1" />
              </svg>
              <strong>Проверено</strong>
              <small>на реальных проектах</small>
            </span>
            <span>
              <svg class="fact-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3 19 6v5c0 4.3-2.8 7.4-7 9-4.2-1.6-7-4.7-7-9V6z" />
                <path d="m9.5 12 1.6 1.7 3.6-4" />
              </svg>
              <strong>Понятно</strong>
              <small>без лишнего героизма</small>
            </span>
          </div>
          <p class="hero-principle">Не идеально, но понятно и работает.</p>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <img src="/images/hero-architecture.svg" alt="" class="hero-diagram" width="320" height="190" />
          <pre class="sticky-note">&lt;?php
solve($problem)
    -&gt;understand()
    -&gt;simplify()
    -&gt;makeItWork()
    -&gt;writeItDown();</pre>
        </div>
      </section>

      {startItems.length > 0 && (
        <section class="home-section card">
          <div class="section-heading">
            <div>
              <h2 class="section-title">С чего начать</h2>
              <p>Первая заметка, с которой начинается этот инженерный блокнот.</p>
            </div>
          </div>
          <div class="start-grid">
            {startItems.map((entry, index) => {
              const collection = entry.collection === 'checklists' ? 'checklists' : 'notes';
              return (
                <a class="start-card" href={hrefFor(collection, entry.id)}>
                  <span class={`item-icon ${iconThemes[index % iconThemes.length]}`}>{collection === 'checklists' ? '✓' : '//'}</span>
                  <span class="item-body">
                    <span class="item-title">{entry.data.title}</span>
                    <span class="item-description">{entry.data.description}</span>
                    <span class="item-tags">{entry.data.tags.slice(0, 3).join(' · ')}</span>
                  </span>
                  <span class="item-arrow" aria-hidden="true">→</span>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {notes.length > 1 && (
        <section class="home-section card">
          <div class="section-heading">
            <h2 class="section-title">Свежие заметки</h2>
          </div>
          <div class="entry-list">
            {notes.slice(0, 4).map((note, index) => (
              <a class="entry-row" href={hrefFor('notes', note.id)}>
                <span class={`item-icon ${iconThemes[index % iconThemes.length]}`}>//</span>
                <span class="entry-content">
                  <span class="item-title">{note.data.title}</span>
                  <span class="item-description">{note.data.description}</span>
                </span>
                <span class="entry-meta">
                  <span class="compact-tags">{note.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}</span>
                  <span>{note.data.pubDate.toLocaleDateString('ru-RU')} · {note.data.readingTime}</span>
                </span>
              </a>
            ))}
          </div>
          <a class="section-link" href="/notes/">Все заметки →</a>
        </section>
      )}
    </div>

    <aside class="home-sidebar" aria-label="Дополнительные материалы">
      <section class="card about-card sidebar-card about-summary">
        <img src="/images/avatar-mpakfm.png" alt="Сергей Фомин" class="about-avatar" width="72" height="72" />
        <div>
          <h2 class="section-title">Коротко обо мне</h2>
          <div class="about-copy">
            <p>Я Сергей Фомин, в интернете — mpakfm.</p>
            <p>Занимаюсь веб-разработкой, внутренними системами и интеграциями. В работе много Bitrix, Git, 1С, API, релизов, старых решений, новых требований и людей, которым надо, чтобы всё просто работало.</p>
            <p>Отдельная часть моей текущей практики — AI-агенты и вайб-кодинг: не как волшебная кнопка, а как способ быстрее думать, черновить, проверять идеи и доводить маленькие задачи до результата.</p>
          </div>
          <a class="section-link about-link" href="/about/">Подробнее обо мне →</a>
        </div>
      </section>

      {checklists.length > 0 && (
        <section class="card sidebar-card checklists-summary">
          <h2 class="section-title">Избранные чек-листы</h2>
          <div class="compact-list">
            {checklists.slice(0, 3).map((item) => (
              <a class="compact-row" href={hrefFor('checklists', item.id)}>
                <span class="item-icon green">✓</span>
                <span>
                  <span class="item-title">{item.data.title}</span>
                  <span class="item-description">{item.data.readingTime}</span>
                </span>
                <span class="item-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
          <a class="section-link" href="/checklists/">Все чек-листы →</a>
        </section>
      )}

      <section class="card sidebar-card topics-summary">
        <h2 class="section-title">Темы</h2>
        <div class="topic-list">
          {topics.map((topic) => <span class="tag">{topic}</span>)}
        </div>
      </section>
    </aside>
  </main>
</BaseLayout>
